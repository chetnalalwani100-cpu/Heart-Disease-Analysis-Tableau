      </column>
      <column caption='Disease Rate' datatype='real' name='[Calculation_1281273332264960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Heart Disease] = &apos;Presence&apos; THEN 1 END )&#13;&#10;/COUNT([Heart Disease])' />
