        <calculation class='tableau' formula='If AVG([Cholesterol])&lt; 200 THEN &quot;normal&quot;&#13;&#10;ELSEIF  AVG([Cholesterol]) &lt;240 THEN &quot;Borderline&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
